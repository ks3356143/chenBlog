---
import type { CollectionEntry } from "astro:content"
import { commentConfig } from "@/config/commentConfig"
import { removeFileExtension } from "@/utils/url-utils"
import Twikoo from "./Twikoo.astro"

interface Props {
    post?: CollectionEntry<"posts"> | CollectionEntry<"spec">
    customPath?: string
    title?: string
}

const { post, customPath, title: customTitle } = Astro.props as Props

// 根据页面类型确定路径
const slugFromPath = (customPath || "/").replace(/^\/+|\/+$/g, "") || "index"
const slug = post ? removeFileExtension(post.id) : slugFromPath
const path = customPath ? customPath : post ? (post.collection === "posts" ? `/posts/${slug}` : `/${slug}`) : `/${slug}`

// 强制commentService类型为string，避免类型不兼容警告
let commentService: string = commentConfig?.type || "none"
---

{
    commentService !== "none" && (
        <div id="post-comments" class="card-base relative mb-6 overflow-hidden p-8">
            {/* <!-- 评论区装饰性背景 --> */}
            <div class="pointer-events-none absolute top-0 right-0 h-32 w-32 opacity-5">
                <svg viewBox="0 0 100 100" class="h-full w-full">
                    <circle cx="50" cy="50" r="40" fill="currentColor" class="text-(--primary)" />
                    <circle
                        cx="50"
                        cy="50"
                        r="25"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        class="text-(--primary)"
                    />
                    <circle cx="50" cy="50" r="10" fill="currentColor" class="text-(--primary)" />
                </svg>
            </div>
            {/* <!-- 评论区标题 --> */}
            <div class="relative z-10 mb-6">
                <div class="mb-2 flex items-center gap-3">
                    <div class="h-6 w-1 rounded-full bg-linear-to-b from-(--primary) to-transparent" />
                    <h3 class="text-xl font-bold text-(--btn-content)">评论区</h3>
                </div>
                <p class="ml-4 text-sm text-(--content-meta)">请分享你的看法，留言、指正和交流</p>
            </div>
            {/* <!-- 评论内容区域 --> */}
            <div class="relative z-10 pr-2 pl-2">
                {commentService === "twikoo" && <Twikoo path={path} />}
                {/* 如果没配置评论，则展示下面 */}
                {commentService === "none" && (
                    <div class="py-8 text-center text-(--content-meta)">
                        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-(--btn-regular-bg)">
                            <svg class="h-8 w-8 text-(--primary)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                                />
                            </svg>
                        </div>
                        <p>评论系统暂未配置</p>
                    </div>
                )}
            </div>
        </div>
    )
}
