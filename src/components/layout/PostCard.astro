---
import type { CollectionEntry } from "astro:content"
import { render } from "astro:content"
import PostMeta from "@/components/layout/PostMeta.astro"
import { siteConfig } from "@/config/siteConfig"
import { getTagUrl } from "@/utils/url-utils"
import { Icon } from "astro-icon/components"
import CoverImage from "@/components/commons/CoverImage.astro"

const COMPDES = "该组件是分页后每一个文章卡片"

interface Props {
	class?: string
	entry: CollectionEntry<"posts">
	title: string
	url: string
	published: Date
	updated?: Date
	tags: string[]
	category: string | null
	image: string
	description: string
	draft: boolean
	pinned?: boolean
	password?: boolean
	style?: string
	loading?: "lazy" | "eager"
}
const {
	entry,
	title,
	url,
	published,
	tags,
	category,
	image,
	description,
	pinned, // 是否顶置
	password, // 是否加锁
	style,
	loading = "lazy",
} = Astro.props
const className = Astro.props.class

// 文章简介取文字 - 如果有description则使用description，否则使用插件的excerpt
const descriptionLines = Math.max(0, Math.trunc(siteConfig.postListLayout.descriptionLines ?? 2))
const descriptionClampLines = String(descriptionLines)
const shouldClampDescription = descriptionLines > 0
const { remarkPluginFrontmatter } = await render(entry)
const descriptionText = description || remarkPluginFrontmatter.excerpt || ""

// 获取文章图片
const coverWidth = "30%"
const hasCoverImage = image ? true : false
---

<div
	class:list={[
		"post-card-wrapper",
		hasCoverImage ? "has-cover" : "no-cover",
		pinned ? "pinned" : "",
		"card-base relative flex w-full flex-col overflow-hidden",
		className,
	]}
	style={style}
>
	<!-- 卡片内容 -->
	<div
		class:list={["post-card-content", "relative flex h-full flex-col pt-4 pr-4 pb-4 pl-4 md:pt-7 md:pb-7 md:pl-9"]}
	>
		<!-- 链接 -->
		<a href={url} class="link-primary group text-90 mb-3 block w-full text-2xl font-bold transition">
			{title}
		</a>
		<!-- 元数据 -->
		<PostMeta published={published} category={category || undefined} />
		<!-- 文章描述 -->
		<div
			class:list={[
				"text-75 description grow transition md:pr-4",
				{ "description-clamped": shouldClampDescription },
			]}
			title={descriptionText}
		>
			{descriptionText}
		</div>
		<!-- tags -->
		<div class="flex flex-wrap gap-2 pt-3 text-sm text-black/30 transition dark:text-white/30">
			{
				tags &&
					tags.map((tag, _i) => (
						<a
							href={getTagUrl(tag)}
							aria-label={`View all posts with the ${tag.trim()} tag`}
							class="btn-regular h-6 px-2 py-1 text-xs transition-all duration-200 stats hover:scale-110 active:scale-95"
						>
							#{tag}
						</a>
					))
			}
		</div>
	</div>
	<!-- 链接按钮-分有封面图和没有封面图 -->
	{
		hasCoverImage && (
			<a
				href={url}
				aria-label={title}
				class:list={[
					"post-card-image",
					"group",
					"w-full md:w-(--coverWidth)",
					"aspect-2/1 md:aspect-auto",
					"relative md:absolute md:top-4 md:right-4 md:bottom-4",
					"overflow-hidden",
				]}
			>
				<div class="pointer-events-none absolute z-10 h-full w-full transition group-hover:bg-black/30 group-active:bg-black/50" />
				<div class="pointer-events-none absolute z-20 flex h-full w-full items-center justify-center">
					<Icon
						name="material-symbols:chevron-right-rounded"
						class="scale-50 text-5xl text-white opacity-0 transition group-hover:scale-100 group-hover:opacity-100"
					/>
				</div>
				<CoverImage
					src={image}
					alt="Cover Image of the Post"
					class="h-full w-full transition-transform duration-300 group-hover:scale-110 group-active:scale-115"
					preview={true}
					loading={loading}
				/>
			</a>
		)
	}

	{
		!hasCoverImage && (
			<a
				href={url}
				aria-label={title}
				class:list={[
					"post-card-enter-btn",
					"btn-regular flex w-13",
					"absolute top-3 right-3 bottom-3 rounded-xl bg-(--enter-btn-bg)",
					"hover:bg-(--enter-btn-bg-hover) active:scale-95 active:bg-(--enter-btn-bg-active)",
				]}
			>
				<Icon
					name="material-symbols:chevron-right-rounded"
					class="mx-auto text-4xl text-(--primary) transition"
				/>
			</a>
		)
	}
</div>

<style define:vars={{ coverWidth, descriptionClampLines }}>
	.description-clamped {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		overflow: hidden;
		-webkit-line-clamp: var(--descriptionClampLines);
		line-clamp: var(--descriptionClampLines);
	}
	/* 移动端列表模式：封面在右侧，内容缩小 */
	.post-card-wrapper {
		flex-direction: row !important;
	}

	.has-cover .post-card-content {
		width: calc(100% - 9rem - 0.75rem) !important;
		padding: 0.75rem 0.5rem 0.75rem 0.75rem !important;
	}

	.has-cover .post-card-image {
		position: absolute !important;
		top: 0.5rem !important;
		bottom: 0.5rem !important;
		right: 0.5rem !important;
		width: 9rem !important;
		aspect-ratio: auto !important;
		border-radius: 0.75rem !important;
	}

	.post-card-title {
		font-size: 1.125rem !important;
		line-height: 1.75rem !important;
		margin-bottom: 0.5rem !important;
	}

	.post-card-title::before {
		display: none !important;
	}

	.stats {
		gap: 0.25rem !important;
	}

	.no-cover .post-card-content {
		width: calc(100% - 52px - 12px) !important;
	}

	.post-card-enter-btn {
		display: flex !important;
	}

	/* 移动端列表模式 - 隐藏tags，只在有空间时显示 */
	.stats a {
		font-size: 0.65rem !important;
		padding: 0.125rem 0.375rem !important;
		height: 1.25rem !important;
	}

	/* 桌面端浏览器 - 内容标准 */
	@media (min-width: 768px) {
		.post-card-wrapper {
			flex-direction: row !important;
		}

		.has-cover .post-card-content {
			width: calc(100% - var(--coverWidth) - 1.5rem) !important;
			padding: 1.75rem 0.5rem 1.75rem 2.25rem !important;
		}

		.has-cover .post-card-image {
			top: 1rem !important;
			bottom: 1rem !important;
			right: 1rem !important;
			width: var(--coverWidth) !important;
			border-radius: 0.75rem !important;
		}

		.post-card-title {
			font-size: 1.5rem !important;
			line-height: 2rem !important;
			margin-bottom: 0.75rem !important;
		}

		.post-card-title::before {
			display: block !important;
			top: 2.25rem !important;
			height: 1rem !important;
		}

		.description {
			font-size: inherit !important;
		}

		.stats a {
			font-size: 0.75rem !important;
			padding: 0.25rem 0.5rem !important;
			height: 1.5rem !important;
		}

		.no-cover .post-card-content {
			width: calc(100% - 52px - 12px) !important;
		}

		.post-card-enter-btn {
			display: flex !important;
		}
	}
</style>
