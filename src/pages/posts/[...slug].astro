---
import type { GetStaticPaths } from "astro"
import { render } from "astro:content"
import { getSortedPosts } from "@/utils/content-utils"
import Layout from "@/layouts/Layout.astro"
import Markdown from "@/components/commons/Markdown.astro"

const DES = "文章详情页面"

// 生成页面函数
export const getStaticPaths = (async () => {
	const blogEntries = await getSortedPosts()
	return blogEntries.map(post => {
		const slug = post.id
		return {
			params: { slug },
			props: { post },
		}
	})
}) satisfies GetStaticPaths

// 文章对象
const { post } = Astro.props

// 获取标题、内容
const { Content, headings } = await render(post)
---

<Layout title={post.data.title}>
	<div class="relative mb-4 flex w-full overflow-hidden">
		<!-- 文章详情页面 -->
		<div id="post-container" class="card-base relative z-10 w-full px-6 pt-6 md:px-9">
			<!-- 待编辑：阅读事件头部东西 -->

			<!-- Markdown渲染 -->
			<Markdown class="markdown-content onload-animation mb-6">
				<Content />
			</Markdown>
		</div>
	</div>
</Layout>
