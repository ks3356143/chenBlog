---
import { getEntry, render } from "astro:content"
import Comment from "@/components/comment/index.astro"
import Markdown from "@/components/commons/Markdown.astro"
import { Icon } from "astro-icon/components"
import { siteConfig } from "@/config/siteConfig"
import { commentConfig } from "@/config/commentConfig"
import Layout from "@/layouts/Layout.astro"

// 检查页面是否启用
if (!siteConfig.pages.guestbook) {
	return Astro.redirect("/404/")
}

const guestbookPost = await getEntry("spec", "guestbook")

if (!guestbookPost) {
	throw new Error("guestbook page content not found")
}

const { Content } = await render(guestbookPost)

// 检查评论系统是否启用
const isCommentEnabled = commentConfig?.type && commentConfig.type !== "none"

// 页面标题和描述
const title = "留言"
---

<Layout title={title}>
	<div class="relative flex min-h-32 w-full overflow-hidden rounded-(--radius-large)">
		<div class="card-base relative z-10 w-full px-9 py-6">
			<!-- 页面标题和描述 -->
			<div class="mb-8">
				<div class="mb-3 flex items-center gap-3">
					<div
						class="flex h-8 w-8 items-center justify-center rounded-lg bg-(--primary) text-white dark:text-black/70"
					>
						<Icon name="material-symbols:chat" class="text-[1.5rem]" />
					</div>
					<div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
						{title}
					</div>
				</div>
				<p class="mb-4 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
					欢迎在这里留下你的足迹，分享你的想法和建议
				</p>
			</div>

			<Markdown class="mt-2">
				<Content />
			</Markdown>
		</div>
	</div>

	<!-- 评论区 -->
	<div class="mt-4">
		{
			isCommentEnabled ? (
				<Comment post={guestbookPost} customPath="/guestbook/" />
			) : (
				<div class="card-base relative mb-6 overflow-hidden p-8">
					<div class="py-8 text-center text-(--content-meta)">
						<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-(--btn-regular-bg)">
							<svg class="h-8 w-8 text-(--primary)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
								/>
							</svg>
						</div>
						<p class="mb-2 text-base">评论区</p>
						<p class="text-sm text-(--content-meta) opacity-75">分享你的想法，与站点内用户交流</p>
					</div>
				</div>
			)
		}
	</div>
</Layout>
