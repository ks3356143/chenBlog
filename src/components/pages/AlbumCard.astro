---
interface Props {
	id: string
	name: string
	cover: string
	description?: string
	date?: string
	location?: string
	tags?: string[]
	photoCount: number
}

const { id, name, cover, description, date, location, tags, photoCount } = Astro.props
---

<a
	href={`/gallery/${id}/`}
	data-tags={tags?.join(",") || ""}
	class="album-card group relative block overflow-hidden rounded-xl transition-all duration-300 hover:scale-[1.02] hover:shadow-lg"
>
	<!-- 封面图片 -->
	<div class="relative aspect-4/3 overflow-hidden">
		{
			cover ? (
				<img
					src={cover}
					alt={name}
					class="pointer-events-none h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
					loading="lazy"
					decoding="async"
				/>
			) : (
				<div class="flex h-full w-full items-center justify-center bg-gray-200 dark:bg-gray-700">
					<div class="text-5xl text-gray-400">&#x1f4f7;</div>
				</div>
			)
		}

		<!-- 照片个数徽章 -->
		<div
			class="absolute top-2 right-2 rounded-full bg-black/50 px-2 py-1 text-xs font-medium text-white backdrop-blur-sm"
		>
			{photoCount} 张图片
		</div>

		<!-- 元数组简介 -->
		<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
		<div class="absolute right-0 bottom-0 left-0 p-4">
			<h3 class="line-clamp-1 text-base font-bold text-white drop-shadow-lg">
				{name}
			</h3>

			{
				description && (
					<p class="mt-1 line-clamp-1 text-xs leading-relaxed text-white/75" title={description}>
						{description}
					</p>
				)
			}

			<div class="mt-1.5 flex flex-wrap items-center gap-3 text-xs text-white/70">
				{date && <span>{date}</span>}
				{
					location && (
						<span class="inline-flex items-center gap-0.5">
							<svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z" />
							</svg>
							{location}
						</span>
					)
				}
			</div>

			{
				tags && tags.length > 0 && (
					<div class="mt-2 flex flex-wrap gap-1">
						{tags.slice(0, 4).map(tag => (
							<span class="rounded bg-white/20 px-1.5 py-0.5 text-[0.6rem] text-white/90 backdrop-blur-sm">
								{tag}
							</span>
						))}
					</div>
				)
			}
		</div>
	</div>
</a>
